# Hide all locally-built APK artifacts. The repo only carries source +
# config; the actual APK + synced web assets live only on Julie's
# machine.

# Synced standalone build (regenerated by scripts/sync-web.sh)
android/app/src/main/assets/

# Build outputs
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/captures/

# Gradle wrapper jar — Android Studio downloads on import,
# or run `gradle wrapper` locally.
android/gradle/wrapper/gradle-wrapper.jar

# Signing keystores must never be committed
*.keystore
*.jks
key.properties

# Built APK / AAB artifacts
*.apk
*.aab
