# Copy to `.env` for local development. All variables are optional except DATABASE_URL.

# Node environment. Use "production" to serve the pre-built static client
# from dist/public; anything else runs the Vite dev server.
NODE_ENV=production

# Neon Postgres connection string (required). Get this from your Neon project
# dashboard — use the "psql" (non-pooled) connection string.
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# Port the server listens on. Defaults to 5000 when unset. On Render this is
# injected automatically — do not set it there.
# PORT=5000

# ── WASM Seed Finder ─────────────────────────────────────────────────────────
# Set to 0 to force JS finder even in production. Default: 1 (WASM enabled).
# VITE_WASM_FINDER=1

# ── Firebase Authentication + Firestore ──────────────────────────────────────
# Required for Google Sign-In and optional cloud sync.
# Get these from Firebase Console → Project Settings → Web app → Config.
# If not set, cloud sync is unavailable but the app functions fully offline.
#
# VITE_FIREBASE_API_KEY=AIzaSy...
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# VITE_FIREBASE_APP_ID=1:123456789:web:abc123
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
